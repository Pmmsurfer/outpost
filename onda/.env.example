# Supabase (required for dashboard auth, profile, retreats, storage)
# Copy this file to .env.local and fill in the values from your Supabase project.
# Dashboard: Project Settings → API → Project URL and anon public key.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL for OAuth redirects (e.g. http://localhost:3000 or https://yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Sheet integration (optional). Create OAuth 2.0 credentials in Google Cloud Console:
# APIs & Services → Credentials → Create OAuth client ID (Web application).
# Add redirect URI: NEXT_PUBLIC_APP_URL/api/integrations/google/callback
# Enable Google Sheets API and Google Drive API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
